{
  "rewrites": [
    {
      "source": "/api/bootstrap/:path*",
      "destination": "https://api.picoin.science/:path*"
    },
    {
      "source": "/api/pool1/:path*",
      "destination": "https://pool1.picoin.science/:path*"
    },
    {
      "source": "/api/pool1-node/:path*",
      "destination": "https://pool1-node.picoin.science/:path*"
    },
    {
      "source": "/api/validator/:path*",
      "destination": "https://api.picoin.science/:path*"
    },
    {
      "source": "/wallet",
      "destination": "/wallet.html"
    },
    {
      "source": "/explorer",
      "destination": "/explorer.html"
    },
    {
      "source": "/miner",
      "destination": "/miner.html"
    },
    {
      "source": "/pool1",
      "destination": "/pool1.html"
    },
    {
      "source": "/transaction",
      "destination": "/transaction.html"
    },
    {
      "source": "/tx/:hash",
      "destination": "/transaction.html?hash=:hash"
    },
    {
      "source": "/picoin-api/:path*",
      "destination": "https://api.picoin.science/:path*"
    }
  ]
}

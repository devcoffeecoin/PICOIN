{
  "name": "picoin-desktop-wallet",
  "version": "0.1.0",
  "description": "Picoin Desktop Wallet V1",
  "author": "Picoin",
  "main": "dist-electron/electron/main/main.js",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build:electron": "tsc -p tsconfig.node.json",
    "build": "npm run build:electron && vite build",
    "electron:dev": "npm run build:electron && concurrently \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "bip39": "^3.1.0",
    "lucide-react": "^0.468.0",
    "qrcode.react": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "science.picoin.wallet",
    "productName": "Picoin Wallet",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/icons",
        "to": "icons",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "resources/icons/picoin-logo.ico",
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false,
      "artifactName": "Picoin-Wallet-Setup-${version}.${ext}"
    },
    "nsis": {
      "installerIcon": "resources/icons/picoin-logo.ico",
      "uninstallerIcon": "resources/icons/picoin-logo.ico",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}

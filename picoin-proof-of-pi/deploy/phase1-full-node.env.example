# Picoin Phase 1 decentralization lab full-node template.
# Copy to /etc/picoin/picoin.env only on isolated test droplets.
# Do not use this file for mainnet.

# Isolated lab identity. These values must not match mainnet.
PICOIN_NETWORK=picoin-phase1-fullnode-lab-v1
PICOIN_CHAIN_ID=31415991
PICOIN_PROTOCOL_VERSION=1.0

# Lab genesis. Use the same allocation file and hash on every Phase 1 droplet.
PICOIN_GENESIS_ALLOCATIONS_FILE=/etc/picoin/phase1-genesis.allocations.json
PICOIN_GENESIS_HASH=CHANGE_ME_PHASE1_GENESIS_HASH

# Lab treasury/governance wallets. Use test wallets only.
PICOIN_TREASURY_WALLET=CHANGE_ME_PHASE1_TREASURY_WALLET
PICOIN_GOVERNANCE_WALLET=CHANGE_ME_PHASE1_GOVERNANCE_WALLET

# Node identity.
PICOIN_NODE_ID=CHANGE_ME_PHASE1_FULL_NODE_ID
PICOIN_NODE_TYPE=full
PICOIN_NODE_ADDRESS=http://CHANGE_ME_FULL_NODE_PUBLIC_IP:8000
PICOIN_BOOTSTRAP_PEERS=http://CHANGE_ME_PHASE1_BOOTSTRAP_IP:8000
PICOIN_BOOTSTRAP_PEER=http://CHANGE_ME_PHASE1_BOOTSTRAP_IP:8000

# API bind and local CLI target.
PICOIN_HOST=0.0.0.0
PICOIN_PORT=8000
PICOIN_SERVER=http://127.0.0.1:8000
PICOIN_HOME=/opt/picoin/picoin-proof-of-pi
PICOIN_DATA_DIR=/var/lib/picoin/data-phase1
PICOIN_DB_PATH=/var/lib/picoin/data-phase1/picoin.sqlite3
PICOIN_WALLET_PATH=/var/lib/picoin/data-phase1/wallets/default.json
PICOIN_BACKUP_DIR=/var/backups/picoin-phase1
PICOIN_SMOKE_DIR=/var/lib/picoin/data-phase1/smoke
PICOIN_RECONCILE_DIR=/var/lib/picoin/data-phase1/reconcile

# Keep full-node droplets read-only for Phase 1.
PICOIN_MINER_SERVER=
PICOIN_MINER_IDENTITY=/var/lib/picoin/data-phase1/identities/miner-disabled.json
PICOIN_MINER_REWARD_ADDRESS=
PICOIN_MINER_LOOPS=1
PICOIN_MINER_SLEEP=10
PICOIN_MINER_WORKERS=1

PICOIN_VALIDATOR_SERVER=
PICOIN_VALIDATOR_NODE_SERVER=http://127.0.0.1:8000
PICOIN_VALIDATOR_NODE_ADDRESS=
PICOIN_VALIDATOR_IDENTITY=/var/lib/picoin/data-phase1/identities/validator-disabled.json
PICOIN_VALIDATOR_REWARD_ADDRESS=
PICOIN_VALIDATOR_LOOPS=1
PICOIN_VALIDATOR_SLEEP=10
PICOIN_WORKER_SLEEP=10

# Conservative node settings.
PICOIN_REQUIRED_VALIDATOR_APPROVALS=3
PICOIN_MINING_TASK_MODE=competitive_round
PICOIN_BLOCK_MATURITY_DEPTH=2
PICOIN_RETARGET_MAX_PI_POSITION=1000000000000000
PICOIN_FAUCET_ALLOWED_NETWORKS=
PICOIN_ALLOW_DIRECT_SCIENCE_GOVERNANCE=0
PICOIN_ALLOW_DIRECT_TREASURY_CLAIM=0
PICOIN_REPLAY_BATCH_SIZE=10
PICOIN_REPLAY_BACKLOG_THRESHOLD=25
PICOIN_REPLAY_WORKER_ENABLED=1
PICOIN_REPLAY_WORKER_INTERVAL_SECONDS=1.0
PICOIN_REPLAY_STALL_FAILURES=3
PICOIN_MIN_QUORUM_PEERS=1
PICOIN_AUTO_RECOVERY_ENABLED=0
PICOIN_RECONCILER_SKIP_WITHOUT_PEER=0
PICOIN_RECONCILER_SLEEP_SECONDS=120
PICOIN_RECONCILER_ROUNDS=2
PICOIN_RECONCILER_LIMIT=32
PICOIN_AUDITOR_INTERVAL=300

# Mempool.
PICOIN_MEMPOOL_TX_TTL_SECONDS=3600
PICOIN_MEMPOOL_MAX_FEE=31.416
PICOIN_MAX_TRANSACTIONS_PER_BLOCK=100
PICOIN_MIN_TX_FEE_UNITS=0
PICOIN_MAX_MEMPOOL_TXS=10000
PICOIN_MAX_MEMPOOL_TXS_PER_ACCOUNT=100
PICOIN_MAX_TX_SIZE_BYTES=16384

# Peer and checkpoint behavior.
PICOIN_GOSSIP_ENABLED=1
PICOIN_GOSSIP_TIMEOUT_SECONDS=2.0
PICOIN_GOSSIP_MAX_PEERS=16
PICOIN_PEER_TIMEOUT_SECONDS=90
PICOIN_PEER_DISCOVERY_ENABLED=1
PICOIN_PEER_DISCOVERY_INTERVAL_SECONDS=300
PICOIN_PEER_DISCOVERY_MAX_PEERS=32
PICOIN_CHECKPOINT_INTERVAL_BLOCKS=10
PICOIN_SCIENCE_RESERVE_AUTHORIZED_SIGNERS=CHANGE_ME_PHASE1_SIGNER_1,CHANGE_ME_PHASE1_SIGNER_2

# Picoin Mainnet v1
# Official production template for mainnet operators.
# Copy to /etc/picoin/picoin.env only for a mainnet rehearsal or launch.
# Every CHANGE_ME value must be replaced before starting services.

# Canonical mainnet identity. These values are frozen by code.
PICOIN_NETWORK=picoin-mainnet-v1
PICOIN_CHAIN_ID=314159
PICOIN_PROTOCOL_VERSION=1.0

# Genesis. Keep the final allocation file identical across all launch nodes.
# If PICOIN_GENESIS_HASH is blank, the node computes it from the allocation file.
# Before launch, compute and publish:
#   python3 -m picoin node genesis-hash --file deploy/mainnet-genesis.allocations.final.json --mainnet
# Mainnet rejects draft, placeholder, non-wallet, and non-canonical wallet allocations.
PICOIN_GENESIS_ALLOCATIONS_FILE=CHANGE_ME_FINAL_MAINNET_GENESIS_ALLOCATIONS_JSON
PICOIN_GENESIS_HASH=

# Required mainnet wallets. Generate these offline and copy only the addresses.
# Mainnet refuses to start with empty, placeholder, non-canonical, or duplicate values.
PICOIN_TREASURY_WALLET=CHANGE_ME_CANONICAL_PI_TREASURY_WALLET
PICOIN_GOVERNANCE_WALLET=CHANGE_ME_CANONICAL_PI_GOVERNANCE_WALLET

# Node identity.
PICOIN_NODE_ID=CHANGE_ME_MAINNET_NODE_ID
PICOIN_NODE_TYPE=bootstrap
PICOIN_NODE_ADDRESS=https://CHANGE_ME_MAINNET_NODE_DOMAIN
PICOIN_BOOTSTRAP_PEERS=
PICOIN_BOOTSTRAP_PEER=

# API bind and local CLI target.
PICOIN_HOST=0.0.0.0
PICOIN_PORT=8000
PICOIN_SERVER=http://127.0.0.1:8000
PICOIN_HOME=/opt/picoin/picoin-proof-of-pi
PICOIN_DATA_DIR=/var/lib/picoin/data
PICOIN_DB_PATH=/var/lib/picoin/data/picoin.sqlite3
PICOIN_WALLET_PATH=/var/lib/picoin/data/wallets/default.json
PICOIN_BACKUP_DIR=/var/backups/picoin
PICOIN_SMOKE_DIR=/var/lib/picoin/data/mainnet/smoke
PICOIN_RECONCILE_DIR=/var/lib/picoin/data/mainnet/reconcile

# Frozen or conservative launch parameters.
PICOIN_REQUIRED_VALIDATOR_APPROVALS=3
PICOIN_MINING_TASK_MODE=competitive_round
PICOIN_BLOCK_MATURITY_DEPTH=2
PICOIN_RETARGET_MAX_PI_POSITION=1000000000000000
PICOIN_FAUCET_ALLOWED_NETWORKS=
PICOIN_ALLOW_DIRECT_SCIENCE_GOVERNANCE=0
PICOIN_ALLOW_DIRECT_TREASURY_CLAIM=0
PICOIN_REPLAY_BATCH_SIZE=10
PICOIN_REPLAY_BACKLOG_THRESHOLD=25
PICOIN_REPLAY_WORKER_ENABLED=1
PICOIN_REPLAY_WORKER_INTERVAL_SECONDS=1.0
PICOIN_REPLAY_STALL_FAILURES=3
PICOIN_MIN_QUORUM_PEERS=1
PICOIN_AUTO_RECOVERY_ENABLED=0
PICOIN_RECONCILER_SLEEP_SECONDS=120
PICOIN_RECONCILER_ROUNDS=2
PICOIN_RECONCILER_LIMIT=32
PICOIN_RECONCILER_SKIP_WITHOUT_PEER=1
PICOIN_AUDITOR_INTERVAL=300

# Mempool.
PICOIN_MEMPOOL_TX_TTL_SECONDS=3600
PICOIN_MEMPOOL_MAX_FEE=31.416
PICOIN_MAX_TRANSACTIONS_PER_BLOCK=100
PICOIN_MIN_TX_FEE_UNITS=0
PICOIN_MAX_MEMPOOL_TXS=10000
PICOIN_MAX_MEMPOOL_TXS_PER_ACCOUNT=100
PICOIN_MAX_TX_SIZE_BYTES=16384

# Worker services. Keep disabled until identities and reward wallets are final.
PICOIN_MINER_SERVER=https://CHANGE_ME_MAINNET_API_DOMAIN
PICOIN_MINER_IDENTITY=/var/lib/picoin/data/mainnet/identities/miner-mainnet.json
PICOIN_MINER_REWARD_ADDRESS=CHANGE_ME_CANONICAL_PI_MINER_REWARD_WALLET
PICOIN_MINER_LOOPS=1
PICOIN_MINER_SLEEP=5
PICOIN_MINER_WORKERS=1

PICOIN_VALIDATOR_SERVER=https://CHANGE_ME_MAINNET_API_DOMAIN
PICOIN_VALIDATOR_NODE_SERVER=http://127.0.0.1:8000
PICOIN_VALIDATOR_NODE_ADDRESS=https://CHANGE_ME_MAINNET_VALIDATOR_NODE_DOMAIN
PICOIN_VALIDATOR_IDENTITY=/var/lib/picoin/data/mainnet/identities/validator-mainnet.json
PICOIN_VALIDATOR_REWARD_ADDRESS=CHANGE_ME_CANONICAL_PI_VALIDATOR_REWARD_WALLET
PICOIN_VALIDATOR_LOOPS=1
PICOIN_VALIDATOR_SLEEP=5
PICOIN_WORKER_SLEEP=10

# Public web/explorer origins.
PICOIN_CORS_ORIGINS=https://CHANGE_ME_MAINNET_EXPLORER_DOMAIN,https://CHANGE_ME_MAINNET_SITE_DOMAIN

# P2P/gossip and peer discovery.
PICOIN_GOSSIP_ENABLED=1
PICOIN_GOSSIP_TIMEOUT_SECONDS=2.0
PICOIN_GOSSIP_MAX_PEERS=16
PICOIN_PEER_TIMEOUT_SECONDS=90
PICOIN_PEER_DISCOVERY_ENABLED=1
PICOIN_PEER_DISCOVERY_INTERVAL_SECONDS=300
PICOIN_PEER_DISCOVERY_MAX_PEERS=32

# Checkpoints and reserve governance.
PICOIN_CHECKPOINT_INTERVAL_BLOCKS=10
PICOIN_SCIENCE_RESERVE_AUTHORIZED_SIGNERS=CHANGE_ME_SIGNER_1,CHANGE_ME_SIGNER_2

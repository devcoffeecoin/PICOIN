# Picoin Marketplace API
PICOIN_MARKETPLACE_STATE_DIR=/var/lib/picoin-marketplace
PICOIN_MARKETPLACE_HOST=127.0.0.1
PICOIN_MARKETPLACE_PORT=9410
PICOIN_MARKETPLACE_SEED_DEFAULT_POOLS=1
PICOIN_MARKETPLACE_SESSION_SECRET=change-me-before-production
PICOIN_MARKETPLACE_SECURE_COOKIES=0

# Picoin payment rail
PICOIN_MARKETPLACE_ESCROW_ADDRESS=PI_MARKETPLACE_ESCROW
PICOIN_MARKETPLACE_CONFIRMATIONS_REQUIRED=3
PICOIN_MARKETPLACE_PICOIN_NODE_URL=http://127.0.0.1:8000
PICOIN_MARKETPLACE_FEE_PERCENT=1

# Ethereum / EVM payment rail
PICOIN_MARKETPLACE_EVM_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
PICOIN_MARKETPLACE_ETH_CONFIRMATIONS=12
PICOIN_MARKETPLACE_USDT_CONTRACT_ADDRESS=0xdAC17F958D2ee523a2206206994597C13D831ec7
PICOIN_MARKETPLACE_USDC_CONTRACT_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
PICOIN_MARKETPLACE_USDT_PICOIN_RATE=1
PICOIN_MARKETPLACE_USDC_PICOIN_RATE=1
PICOIN_MARKETPLACE_ETH_RPC_URLS=
PICOIN_MARKETPLACE_EVM_RPC_URL=

# Scanner loop
PICOIN_MARKETPLACE_SCANNER_INTERVAL_SECONDS=30
PICOIN_MARKETPLACE_SCANNER_PICOIN_ENABLED=1
PICOIN_MARKETPLACE_SCANNER_PICOIN_LIMIT=50
PICOIN_MARKETPLACE_SCANNER_EVM_TOKENS_ENABLED=0
PICOIN_MARKETPLACE_SCANNER_EVM_NATIVE_ENABLED=0
PICOIN_MARKETPLACE_SCANNER_EVM_CHAIN_CODE=ethereum
PICOIN_MARKETPLACE_SCANNER_EVM_TOKEN_SYMBOLS=USDT,USDC
PICOIN_MARKETPLACE_SCANNER_EVM_NATIVE_TOKEN_SYMBOL=ETH
PICOIN_MARKETPLACE_SCANNER_EVM_BATCH_SIZE=500
PICOIN_MARKETPLACE_SCANNER_EVM_NATIVE_BATCH_SIZE=100
PICOIN_MARKETPLACE_HTTP_TIMEOUT_SECONDS=30

# Maintenance loop
PICOIN_MARKETPLACE_MAINTENANCE_INTERVAL_SECONDS=30
PICOIN_MARKETPLACE_WORKER_STALE_AFTER_SECONDS=120
PICOIN_MARKETPLACE_MAINTENANCE_LIMIT=1000

# Optional real paired miner worker. For a real PICOIN/MONERO pair, configure
# one Picoin miner command and one paired-coin miner command. The legacy
# PICOIN_MARKETPLACE_MINER_COMMAND key remains accepted as an alias for the
# paired command.
PICOIN_MARKETPLACE_WORKER_ID=real-monero-1
PICOIN_MARKETPLACE_WORKER_PROVIDER_ID=provider-cpu-1
PICOIN_MARKETPLACE_WORKER_PROVIDER_WALLET=PI_PROVIDER_WALLET
PICOIN_MARKETPLACE_WORKER_HARDWARE_TYPE=cpu
PICOIN_MARKETPLACE_WORKER_POOL_ID=
PICOIN_MARKETPLACE_WORKER_UNITS_TOTAL=1
PICOIN_MARKETPLACE_WORKER_PRICE_PI_PER_HOUR=1
PICOIN_MARKETPLACE_MINER_PAIRED_COIN=MONERO
PICOIN_MARKETPLACE_PICOIN_MINER_COMMAND=
PICOIN_MARKETPLACE_PICOIN_MINER_CWD=
PICOIN_MARKETPLACE_PICOIN_MINER_API_URL=
PICOIN_MARKETPLACE_PAIRED_MINER_COMMAND=
PICOIN_MARKETPLACE_PAIRED_MINER_CWD=
PICOIN_MARKETPLACE_PAIRED_MINER_API_URL=
PICOIN_MARKETPLACE_REQUIRE_PICOIN_MINER=0
PICOIN_MARKETPLACE_PICOIN_CAPACITY_PERCENT=10
PICOIN_MARKETPLACE_PAIRED_CAPACITY_PERCENT=90
PICOIN_MARKETPLACE_MINER_COMMAND=
PICOIN_MARKETPLACE_MINER_API_URL=
PICOIN_MARKETPLACE_MINER_WARMUP_SECONDS=10
PICOIN_MARKETPLACE_MINER_AUTO_CREATE_POOL=1
